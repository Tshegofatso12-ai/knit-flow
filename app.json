{
  "expo": {
    "name": "KnitFlow",
    "slug": "knit-flow",
    "version": "1.0.0",
    "scheme": "knitflow",
    "orientation": "portrait",
    "icon": "./assets/knitflow.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/knitflow.png",
      "resizeMode": "contain",
      "backgroundColor": "#fdfbf9"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tshegofatsomaseko.knitflow",
      "icon": "./assets/knitflow.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fdfbf9",
        "foregroundImage": "./assets/knitflow.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tshegofatsomaseko.knitflow"
    },
    "web": {
      "favicon": "./assets/knitflow.png"
    },
    "plugins": ["expo-router", "expo-font"]
  }
}
